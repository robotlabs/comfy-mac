{
  "name": "comfy-mac",
  "version": "0.1.0",
  "description": "Send prompts from a Mac to a ComfyUI instance on a GPU PC over the LAN and get images back.",
  "type": "module",
  "scripts": {
    "start": "COMFY_TARGET=local PORT=4242 node server/index.js",
    "local": "COMFY_TARGET=local PORT=4242 node server/index.js",
    "runpod": "COMFY_TARGET=runpod PORT=4243 node server/index.js",
    "dev": "COMFY_TARGET=local PORT=4242 node --watch server/index.js",
    "dev:runpod": "COMFY_TARGET=runpod PORT=4243 node --watch server/index.js"
  },
  "dependencies": {
    "express": "^4.21.2",
    "ws": "^8.18.0"
  }
}
