{
  "1": {
    "inputs": {
      "model_name": "RealESRGAN_x4plus.safetensors"
    },
    "class_type": "UpscaleModelLoader",
    "_meta": { "title": "Load Upscale Model" }
  },
  "9": {
    "inputs": {
      "file": "input.mp4",
      "video-preview": ""
    },
    "class_type": "LoadVideo",
    "_meta": { "title": "Load Video" }
  },
  "10": {
    "inputs": {
      "video": ["9", 0]
    },
    "class_type": "GetVideoComponents",
    "_meta": { "title": "Get Video Components" }
  },
  "2": {
    "inputs": {
      "upscale_model": ["1", 0],
      "image": ["10", 0]
    },
    "class_type": "ImageUpscaleWithModel",
    "_meta": { "title": "Upscale (GAN, scala del modello)" }
  },
  "3": {
    "inputs": {
      "upscale_method": "lanczos",
      "width": 1080,
      "height": 1920,
      "crop": "disabled",
      "image": ["2", 0]
    },
    "class_type": "ImageScale",
    "_meta": { "title": "Resize finale (target esatto)" }
  },
  "11": {
    "inputs": {
      "fps": ["10", 2],
      "images": ["3", 0],
      "audio": ["10", 1]
    },
    "class_type": "CreateVideo",
    "_meta": { "title": "Create Video" }
  },
  "12": {
    "inputs": {
      "filename_prefix": "video/upscaled",
      "format": "auto",
      "codec": "auto",
      "video": ["11", 0]
    },
    "class_type": "SaveVideo",
    "_meta": { "title": "Save Video" }
  }
}
